<view class="register-container">
  <van-cell-group inset>
    <van-field
      value="{{ nickname }}"
      label="Name"
      placeholder="Enter your name"
      bind:change="onFieldChange"
      data-name="nickname"
    />
    <van-field
      value="{{ phone }}"
      label="Phone"
      placeholder="Enter phone number"
      bind:change="onFieldChange"
      data-name="phone"
      use-button-slot
    >
      <van-button
        slot="button"
        size="small"
        type="primary"
        disabled="{{ codeDisabled }}"
        bindtap="sendVerifyCode"
      >
        {{ codeText }}
      </van-button>
    </van-field>
    <van-field
      value="{{ code }}"
      label="Code"
      placeholder="Enter verify code"
      border="{{ false }}"
      bind:change="onFieldChange"
      data-name="code"
    />
  </van-cell-group>

  <view class="btn-group">
    <van-button type="primary" block round bindtap="handleRegister">Register</van-button>
    <view class="login-link" bindtap="backToLogin">Back to login</view>
  </view>

  <van-toast id="van-toast" />
</view>

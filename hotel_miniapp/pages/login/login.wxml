<view class="login-container">
  <view class="logo-box">
    <image class="logo" src="../../assets/logo.jpg" mode="aspectFit"></image>
    <view class="title">Aventale Hotel Booking</view>
  </view>

  <van-cell-group inset>
    <van-field
      value="{{ phone }}"
      label="Phone"
      placeholder="Enter phone number"
      bind:change="onPhoneChange"
      use-button-slot
    >
      <van-button
        slot="button"
        size="small"
        type="primary"
        disabled="{{ codeDisabled }}"
        bindtap="sendVerifyCode"
      >
        {{ codeText }}
      </van-button>
    </van-field>
    <van-field
      value="{{ code }}"
      label="Code"
      placeholder="Enter verify code"
      border="{{ false }}"
      bind:change="onCodeChange"
    />
  </van-cell-group>

  <view class="btn-group">
    <van-button type="primary" block round bindtap="handleLogin">Login</van-button>
    <view class="register-link" bindtap="goToRegister">Create account</view>
  </view>

  <van-toast id="van-toast" />
</view>

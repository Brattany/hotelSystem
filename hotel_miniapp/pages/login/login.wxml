<view class="login-container">
  <view class="logo-box">
    <image class="logo" src="../../assets/logo.jpg" mode="aspectFit"></image>
    <view class="title">酒店预订</view>
  </view>

  <van-cell-group inset>
    <van-field
      value="{{ phone }}"
      label="手机号"
      placeholder="请输入手机号"
      bind:change="onPhoneChange"
      use-button-slot
    >
      <van-button
        slot="button"
        size="small"
        type="primary"
        disabled="{{ codeDisabled }}"
        bindtap="sendVerifyCode"
      >
        {{ codeText }}
      </van-button>
    </van-field>
    <van-field
      value="{{ code }}"
      label="验证码"
      placeholder="请输入验证码"
      border="{{ false }}"
      bind:change="onCodeChange"
    />
  </van-cell-group>

  <view class="btn-group">
    <van-button type="primary" block round bindtap="handleLogin">登录</van-button>
    <view class="register-link" bindtap="goToRegister">注册账号</view>
  </view>

  <van-toast id="van-toast" />
</view>

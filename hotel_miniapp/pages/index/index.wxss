.home-container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding-bottom: 120rpx; 
}

.search-section {
  padding: 20rpx 0;
  background-color: #fff;
}

.nav-grid {
  margin: 20rpx 0;
  background-color: #fff;
}

.banner-box {
  margin: 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.banner-img {
  width: 100%;
  height: 300rpx;
}

.banner-text {
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}
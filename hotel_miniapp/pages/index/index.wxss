.home-container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.search-section {
  padding: 24rpx 20rpx 0;
}

.search-card {
  background: linear-gradient(135deg, #ffffff 0%, #f2f8ff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(25, 137, 250, 0.08);
}

.search-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #323233;
}

.search-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #969799;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.search-field {
  flex: 1;
  background-color: #ffffff;
  border-radius: 999rpx;
  overflow: hidden;
}

.search-btn {
  flex-shrink: 0;
  min-width: 140rpx !important;
  height: 72rpx !important;
}

.quick-section {
  margin: 20rpx 20rpx 0;
}

.section-title {
  padding: 8rpx 8rpx 16rpx;
  font-size: 28rpx;
  color: #646566;
}

.quick-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.quick-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background-color: rgba(25, 137, 250, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-content {
  flex: 1;
  margin-left: 20rpx;
}

.quick-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.quick-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #969799;
}

.quick-arrow {
  margin-left: 16rpx;
}

.quick-tip {
  margin-top: 16rpx;
  padding: 0 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #969799;
}

.banner-box {
  margin: 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.banner-img {
  width: 100%;
  height: 300rpx;
}

.banner-text {
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
}

.service-fab {
  position: fixed;
  right: 24rpx;
  bottom: 180rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 20rpx 16rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1989fa 0%, #33a1ff 100%);
  box-shadow: 0 12rpx 28rpx rgba(25, 137, 250, 0.24);
}

.service-fab-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.service-fab-text {
  color: #ffffff;
}

.service-fab-title {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
}

.service-fab-subtitle {
  margin-top: 4rpx;
  font-size: 20rpx;
  opacity: 0.9;
  line-height: 1.2;
}
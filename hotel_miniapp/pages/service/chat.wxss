.chat-page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
}

.chat-header {
  margin: 24rpx 20rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f2f8ff 100%);
  box-shadow: 0 10rpx 30rpx rgba(25, 137, 250, 0.08);
}

.chat-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #323233;
}

.chat-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #969799;
}

.status-bar {
  margin: 16rpx 20rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff7eb;
  color: #ed6a0c;
}

.status-text {
  font-size: 24rpx;
  line-height: 1.5;
}

.quick-actions {
  padding: 16rpx 20rpx 0;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #1989fa;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.message-list {
  flex: 1;
  padding: 20rpx 20rpx 180rpx;
  box-sizing: border-box;
}

.message-row {
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.user-row {
  flex-direction: row-reverse;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
}

.assistant-avatar {
  background: #1989fa;
}

.user-avatar {
  background: #07c160;
}

.bubble-wrap {
  max-width: 74%;
}

.bubble {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}

.assistant-bubble {
  background: #ffffff;
  color: #323233;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.user-bubble {
  background: #1989fa;
  color: #ffffff;
  border-top-right-radius: 8rpx;
}

.bubble-tip {
  margin-top: 8rpx;
  padding-left: 8rpx;
  font-size: 22rpx;
  color: #969799;
}

.result-panel {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-card {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #323233;
}

.result-line {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #646566;
}

.loading-bubble {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  border-top-left-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.loading-text {
  font-size: 26rpx;
  color: #646566;
}

.error-bar {
  margin: 0 20rpx 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff1f0;
  color: #ee0a24;
  font-size: 24rpx;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  background: rgba(247, 248, 250, 0.96);
  backdrop-filter: blur(8rpx);
  box-sizing: border-box;
}

.input-area {
  flex: 1;
  min-height: 84rpx;
  max-height: 220rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

.send-btn {
  min-width: 140rpx !important;
  height: 84rpx !important;
}

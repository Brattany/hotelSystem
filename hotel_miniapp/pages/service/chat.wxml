<view class="chat-page">
  <view class="chat-header">
    <view class="chat-title">智能客服</view>
    <view class="chat-subtitle">可咨询酒店搜索、订单查询、修改取消，以及知识库问答</view>
  </view>

  <view class="quick-actions">
    <view class="quick-chip" bindtap="onQuickAsk" data-question="帮我查成都附近的酒店">查酒店</view>
    <view class="quick-chip" bindtap="onQuickAsk" data-question="帮我查最近订单">最近订单</view>
    <view class="quick-chip" bindtap="onQuickAsk" data-question="酒店最晚几点退房？">知识问答</view>
    <view class="quick-chip" bindtap="onQuickAsk" data-question="帮我取消最近预订的订单">取消订单</view>
  </view>

  <scroll-view class="message-list" scroll-y scroll-with-animation scroll-into-view="{{ scrollIntoView }}">
    <view
      wx:for="{{ messages }}"
      wx:key="id"
      wx:for-item="item"
      id="msg-{{ item.id }}"
      class="message-row {{ item.role === 'user' ? 'user-row' : 'assistant-row' }}"
    >
      <view class="avatar {{ item.role === 'user' ? 'user-avatar' : 'assistant-avatar' }}">
        {{ item.role === 'user' ? '我' : '客服' }}
      </view>
      <view class="bubble-wrap">
        <view class="bubble {{ item.role === 'user' ? 'user-bubble' : 'assistant-bubble' }}">
          {{ item.content }}
        </view>
        <view class="bubble-tip" wx:if="{{ item.intentLabel || item.intent }}">{{ item.intentLabel || item.intent }}</view>

        <view class="result-panel" wx:if="{{ item.messageType === 'hybrid_result' }}">
          <view class="result-card">
            <view class="result-title">混合查询结果</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.knowledgeQuery }}">知识问题：{{ item.structuredData.queryDisplay.knowledgeQuery }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.hasHotelResults }}">已返回 {{ item.structuredData.hotels.length }} 家酒店结果</view>
            <view class="result-line" wx:if="{{ item.structuredData.hasOrderResults }}">已返回 {{ item.structuredData.displayOrders.length }} 条订单结果</view>
            <view class="result-line" wx:if="{{ item.structuredData.hasReservation }}">已返回订单详情</view>
            <view class="result-line" wx:if="{{ item.structuredData.hasKnowledge }}">已补充知识库规则说明</view>
            <view class="result-line" wx:if="{{ !item.structuredData.hasHotelResults && !item.structuredData.hasOrderResults && !item.structuredData.hasReservation }}">当前结构化部分未命中，已优先展示规则说明。</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ (item.messageType === 'hotel_result' || item.messageType === 'hybrid_result') && item.structuredData.hotels && item.structuredData.hotels.length }}">
          <view class="result-card">
            <view class="result-title">共找到 {{ item.structuredData.total || item.structuredData.hotels.length }} 家酒店</view>
            <view class="result-line" wx:if="{{ item.hotelMatchLabel }}">结果类型：{{ item.hotelMatchLabel }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.location.province }}">省份：{{ item.structuredData.queryDisplay.location.province }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.location.city }}">城市：{{ item.structuredData.queryDisplay.location.city }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.location.district }}">区域：{{ item.structuredData.queryDisplay.location.district }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.location.street }}">街道：{{ item.structuredData.queryDisplay.location.street }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.location.addressKeyword }}">地址关键词：{{ item.structuredData.queryDisplay.location.addressKeyword }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.hotelName }}">酒店名：{{ item.structuredData.queryDisplay.hotelName }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.facilitySummary }}">服务条件：{{ item.structuredData.queryDisplay.facilitySummary }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.queryDisplay.roomTypeLabel }}">房型条件：{{ item.structuredData.queryDisplay.roomTypeLabel }}</view>
          </view>
          <view class="result-card" wx:for="{{ item.structuredData.hotels }}" wx:for-item="hotel" wx:key="hotelId">
            <view class="result-title">{{ hotel.hotelName || '未命名酒店' }}</view>
            <view class="result-line">地址：{{ hotel.fullAddress || hotel.address || '暂无地址' }}</view>
            <view class="result-line">电话：{{ hotel.phone || '暂无电话' }}</view>
            <view class="result-line">参考价：{{ hotel.minPrice || '暂无' }}</view>
            <view class="result-line">评分：{{ hotel.rating || '暂无' }}</view>
            <view class="result-line">WiFi：{{ hotel.hasWifi ? '有' : '无' }}</view>
            <view class="result-line">早餐：{{ hotel.hasBreakfast ? '有' : '无' }}</view>
            <view class="result-line">停车场：{{ hotel.hasParking ? '有' : '无' }}</view>
            <view class="result-line" wx:if="{{ hotel.matchedRoomTypesLabel }}">匹配房型：{{ hotel.matchedRoomTypesLabel }}</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ (item.messageType === 'order_list' || item.messageType === 'hybrid_result') && item.structuredData.displayOrders && item.structuredData.displayOrders.length }}">
          <view class="result-card">
            <view class="result-title">共找到 {{ item.structuredData.total || item.structuredData.displayOrders.length }} 条订单</view>
            <view class="result-line" wx:if="{{ item.structuredData.multiple }}">当前匹配到多条候选订单，请继续确认目标订单。</view>
            <view class="result-line">可继续输入“修改第一条”“取消第二条”，或明确说明订单号。</view>
          </view>
          <view class="result-card" wx:for="{{ item.structuredData.displayOrders }}" wx:for-item="order" wx:key="orderId">
            <view class="result-title">订单号：{{ order.orderNo || order.orderId || order.reservationId }}</view>
            <view class="result-line">酒店：{{ order.hotelName || '暂无' }}</view>
            <view class="result-line" wx:if="{{ order.regionLabel }}">地区：{{ order.regionLabel }}</view>
            <view class="result-line" wx:if="{{ order.hotelAddress }}">地址：{{ order.hotelAddress }}</view>
            <view class="result-line">房型：{{ order.roomTypeName || '暂无' }}</view>
            <view class="result-line">日期：{{ order.checkInDate || '暂无' }} - {{ order.checkOutDate || '暂无' }}</view>
            <view class="result-line">金额：{{ order.totalPrice || '暂无' }}</view>
            <view class="result-line">状态：{{ order.statusText || '暂无' }}</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ (item.messageType === 'order_detail' || item.messageType === 'hybrid_result') && item.structuredData.reservation }}">
          <view class="result-card">
            <view class="result-title">订单号：{{ item.structuredData.reservation.orderNo || item.structuredData.reservation.orderId || item.structuredData.reservation.reservationId }}</view>
            <view class="result-line">酒店：{{ item.structuredData.reservation.hotelName || '暂无' }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.reservation.regionLabel }}">地区：{{ item.structuredData.reservation.regionLabel }}</view>
            <view class="result-line" wx:if="{{ item.structuredData.reservation.hotelAddress }}">地址：{{ item.structuredData.reservation.hotelAddress }}</view>
            <view class="result-line">房型：{{ item.structuredData.reservation.roomTypeName || '暂无' }}</view>
            <view class="result-line">日期：{{ item.structuredData.reservation.checkInDate || '暂无' }} - {{ item.structuredData.reservation.checkOutDate || '暂无' }}</view>
            <view class="result-line">金额：{{ item.structuredData.reservation.totalPrice || '暂无' }}</view>
            <view class="result-line">状态：{{ item.structuredData.reservation.statusText || '暂无' }}</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ item.messageType === 'hotel_empty' }}">
          <view class="result-card">
            <view class="result-title">酒店查询结果</view>
            <view class="result-line">当前没有查到匹配酒店，您可以继续补充城市、区县、酒店名、服务条件或房型。</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ item.messageType === 'order_empty' }}">
          <view class="result-card">
            <view class="result-title">订单查询结果</view>
            <view class="result-line">当前没有查到匹配订单，您可以补充酒店名、地区、时间范围，或直接说明“最近订单”。</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ item.messageType === 'knowledge_empty' }}">
          <view class="result-card">
            <view class="result-title">知识问答结果</view>
            <view class="result-line">当前知识库没有命中相关内容，您可以换个问法，或补充更明确的规则主题。</view>
          </view>
        </view>

        <view class="result-panel" wx:if="{{ item.structuredData.hasKnowledge }}">
          <view class="result-card">
            <view class="result-title">{{ item.structuredData.knowledgeRouteLabel || '知识库结果' }}</view>
            <view class="result-line">共命中 {{ item.structuredData.knowledge.total || item.structuredData.knowledge.hits.length }} 条知识片段</view>
            <view class="result-line" wx:if="{{ item.structuredData.routeType === 'hybrid' }}">当前回答已结合结构化查询与知识库补充信息。</view>
          </view>

          <view class="result-card" wx:if="{{ item.structuredData.knowledge.sources && item.structuredData.knowledge.sources.length }}">
            <view class="result-title">参考来源</view>
            <view class="source-list">
              <view class="source-chip" wx:for="{{ item.structuredData.knowledge.sources }}" wx:key="index" wx:for-item="source">
                {{ source.source || source.fileName || '知识文档' }}
              </view>
            </view>
          </view>

          <view class="result-card" wx:for="{{ item.structuredData.knowledge.hits }}" wx:key="index" wx:for-item="hit">
            <view class="result-title">{{ hit.source || hit.fileName || '知识片段' }}</view>
            <view class="result-line" wx:if="{{ hit.docType }}">类型：{{ hit.docType }}</view>
            <view class="result-line" wx:if="{{ hit.scoreText }}">匹配度：{{ hit.scoreText }}</view>
            <view class="result-line">{{ hit.preview || '暂无摘要' }}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="message-row assistant-row" wx:if="{{ sending }}">
      <view class="avatar assistant-avatar">客服</view>
      <view class="loading-bubble">
        <van-loading size="32rpx" color="#1989fa" />
        <text class="loading-text">正在回复中...</text>
      </view>
    </view>
  </scroll-view>

  <view class="error-bar" wx:if="{{ errorText }}">{{ errorText }}</view>

  <view class="input-bar">
    <textarea
      class="input-area"
      value="{{ inputValue }}"
      placeholder="请输入您想咨询的问题"
      maxlength="300"
      auto-height
      confirm-type="send"
      bindinput="onInputChange"
    />
    <van-button
      type="info"
      round
      custom-class="send-btn"
      loading="{{ sending }}"
      disabled="{{ sending }}"
      bindtap="handleSend"
    >
      发送
    </van-button>
  </view>
</view>

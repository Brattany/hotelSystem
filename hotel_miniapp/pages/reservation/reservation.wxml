<view class="reservation-container">
  <van-cell-group inset custom-class="section-card">
    <van-cell
      title="Dates"
      value="{{ dateString }}"
      is-link
      bind:click="onDisplayCalendar"
    />
  </van-cell-group>

  <van-calendar
    show="{{ showCalendar }}"
    type="range"
    bind:close="onCloseCalendar"
    bind:confirm="onConfirmCalendar"
    color="#1989fa"
  />

  <view class="section-title">Room Types</view>

  <van-empty wx:if="{{ availableRoomTypes.length === 0 }}" description="Please select dates first" />

  <view class="room-list" wx:else>
    <view
      class="room-card {{ selectedRoomTypeId === item.typeId ? 'active' : '' }}"
      wx:for="{{ availableRoomTypes }}"
      wx:key="typeId"
      bindtap="selectRoomType"
      data-item="{{ item }}"
    >
      <view class="room-info">
        <view class="room-name">{{ item.typeName }}</view>
        <view class="room-desc">Capacity: {{ item.capacity || 0 }} | Left: {{ item.availableCount || 0 }}</view>
      </view>
      <view class="room-price">
        <text class="currency">¥</text>{{ item.price }}
      </view>
    </view>
  </view>

  <view class="section-title">Guest Info</view>
  <van-cell-group inset custom-class="section-card">
    <van-field
      value="{{ guestName }}"
      label="Name"
      placeholder="Enter guest name"
      bind:change="onNameChange"
    />
    <van-field
      value="{{ guestPhone }}"
      label="Phone"
      type="number"
      placeholder="Enter guest phone"
      bind:change="onPhoneChange"
      border="{{ false }}"
    />
  </van-cell-group>

  <van-submit-bar
    price="{{ totalPrice * 100 }}"
    button-text="Submit"
    bind:submit="onSubmitOrder"
    tip="{{ dateString ? days + ' night(s)' : 'Please select dates' }}"
  />

  <van-toast id="van-toast" />
</view>

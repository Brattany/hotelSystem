<view class="reservation-container">
  <view class="hotel-brief">
    <image class="hotel-brief-image" src="{{ hotelCoverImage }}" mode="aspectFill"></image>
    <view class="hotel-brief-content">
      <view class="hotel-brief-label">当前酒店</view>
      <view class="hotel-brief-name">{{ hotelName || '酒店房型预订' }}</view>
      <view class="hotel-brief-tip">先浏览当前日期可订房型，选中后再填写入住日期、数量和入住人信息。</view>
    </view>
  </view>

  <van-calendar
    show="{{ showCalendar }}"
    type="range"
    show-confirm="{{ false }}"
    bind:close="onCloseCalendar"
    bind:confirm="onConfirmCalendar"
    color="#1989fa"
  />

  <view class="section-title">全部房型</view>

  <view class="room-feedback room-feedback--loading" wx:if="{{ roomLoading }}">
    <view class="room-feedback-title">正在查询房型</view>
    <view class="room-feedback-desc">已按 {{ dateString }} 查询当前酒店可预订房型，请稍候。</view>
  </view>

  <view class="room-feedback room-feedback--error" wx:elif="{{ roomErrorMessage }}">
    <view class="room-feedback-title">房型加载失败</view>
    <view class="room-feedback-desc">{{ roomErrorMessage }}</view>
    <van-button size="small" type="primary" plain bindtap="retryFetchRooms">重新查询</van-button>
  </view>

  <van-empty
    wx:elif="{{ availableRoomTypes.length === 0 }}"
    description="{{ roomSearchDone ? '当前日期暂无可订房型' : '正在准备房型数据' }}"
  />

  <view class="room-list" wx:else>
    <view
      class="room-card {{ selectedRoomTypeId === item.roomTypeId ? 'room-card--active' : '' }}"
      wx:for="{{ availableRoomTypes }}"
      wx:key="roomTypeId"
      bindtap="selectRoomType"
      data-item="{{ item }}"
    >
      <image class="room-image" src="{{ item.imageUrl }}" mode="aspectFill"></image>
      <view class="room-body">
        <view class="room-header">
          <view class="room-name">{{ item.typeName }}</view>
          <view class="room-status">{{ selectedRoomTypeId === item.roomTypeId ? '当前已选' : item.statusText }}</view>
        </view>
        <view class="room-tags">
          <view class="room-tag" wx:for="{{ item.detailTags }}" wx:for-item="tag" wx:key="*this">{{ tag }}</view>
        </view>
        <view class="room-extra" wx:if="{{ item.breakfast }}">早餐：{{ item.breakfast }}</view>
        <view class="room-extra" wx:if="{{ item.cancelRule }}">规则：{{ item.cancelRule }}</view>
        <view class="room-desc" wx:if="{{ item.description }}">{{ item.description }}</view>
        <view class="room-footer">
          <view class="room-price"><text class="currency">¥</text>{{ item.price }}</view>
          <view class="room-action">点击选择并预订</view>
        </view>
      </view>
    </view>
  </view>

  <view class="booking-panel" wx:if="{{ selectedRoomInfo }}">
    <view class="section-title">预订所选房型</view>
    <view class="booking-card">
      <view class="booking-room-name">{{ selectedRoomInfo.typeName }}</view>
      <view class="booking-room-meta">入住 {{ days }} 晚，单价 ¥{{ selectedRoomInfo.price }} / 间</view>

      <van-cell-group inset custom-class="booking-cell-group">
        <van-cell title="入住与离店日期" value="{{ dateString }}" is-link bind:click="onDisplayCalendar" />
      </van-cell-group>

      <view class="quantity-block">
        <view>
          <view class="quantity-title">房间数量</view>
          <view class="quantity-desc">{{ selectedRoomInfo.availableCount > 0 ? '当前最多可订 ' + selectedRoomInfo.availableCount + ' 间' : '如后端未返回库存，默认允许继续提交' }}</view>
        </view>
        <view class="quantity-stepper">
          <van-button size="mini" bindtap="decreaseRoomCount">-</van-button>
          <view class="quantity-value">{{ roomCount }}</view>
          <van-button size="mini" type="primary" bindtap="increaseRoomCount">+</van-button>
        </view>
      </view>

      <van-cell-group inset custom-class="booking-cell-group">
        <van-field value="{{ guestName }}" label="姓名" placeholder="请输入入住人姓名" bind:change="onNameChange" />
        <van-field
          value="{{ guestPhone }}"
          label="手机号"
          type="number"
          placeholder="请输入入住人手机号"
          bind:change="onPhoneChange"
          border="{{ false }}"
        />
      </van-cell-group>
    </view>

    <van-submit-bar
      price="{{ totalPrice * 100 }}"
      button-text="提交订单"
      bind:submit="onSubmitOrder"
      tip="已选 {{ selectedRoomInfo.typeName }}，共 {{ roomCount }} 间 / {{ days }} 晚"
    />
  </view>

  <van-toast id="van-toast" />
  <van-dialog id="van-dialog" />
</view>

.profile-container {
  min-height: 100vh;
  background-color: #f7f8fa;
}

.user-header {
  background: linear-gradient(180deg, #1989fa 0%, #1989fa 60%, #f7f8fa 100%);
  padding: 40rpx 32rpx 100rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  padding: 30rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
}

.user-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-info {
  margin-left: 30rpx;
  color: #fff;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
}

.user-phone {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.menu-section {
  margin-top: -60rpx; 
  position: relative;
  z-index: 1;
}

.logout-section {
  margin: 60rpx 32rpx;
}

.van-cell__left-icon {
  font-size: 40rpx !important;
  margin-right: 20rpx !important;
  color: #1989fa;
}
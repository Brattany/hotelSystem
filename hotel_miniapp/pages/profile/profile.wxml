<view class="profile-container">
  <view class="user-header">
    <view class="user-card">
      <van-image
        round
        width="120rpx"
        height="120rpx"
        src="../../assets/logo.jpg"
        custom-class="user-avatar"
      />
      <view class="user-info">
        <view class="user-name">{{ userInfo ? (userInfo.name || 'Guest') : 'Not Logged In' }}</view>
        <view class="user-phone">{{ userInfo ? (userInfo.phone || '-') : 'Please login first' }}</view>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <van-cell-group inset>
      <van-cell
        title="My Orders"
        icon="orders-o"
        is-link
        bind:click="goToOrders"
      />
      <van-cell
        title="Profile"
        icon="user-o"
        is-link
        bind:click="navigateToEdit"
      />
    </van-cell-group>
  </view>

  <view class="logout-section" wx:if="{{ userInfo && userInfo.phone }}">
    <van-button block round color="#ee0a24" plain bindtap="handleLogout">
      Logout
    </van-button>
  </view>

  <view class="logout-section" wx:else>
    <van-button block round type="primary" bindtap="goToLogin">
      Login
    </van-button>
  </view>

  <van-dialog id="van-dialog" />
</view>

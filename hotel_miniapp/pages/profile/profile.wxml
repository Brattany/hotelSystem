<view class="profile-container">
  <view class="user-header">
    <view class="user-card">
      <van-image
        round
        width="120rpx"
        height="120rpx"
        src="{{ userInfo ? userInfo.avatarUrl : defaultAvatar }}"
        custom-class="user-avatar"
      />
      <view class="user-info">
        <view class="user-name">{{ userInfo ? (userInfo.name || '游客') : '未登录' }}</view>
        <view class="user-phone">{{ userInfo ? (userInfo.phone || '-') : '请先登录' }}</view>
      </view>
    </view>

    <view class="avatar-actions" wx:if="{{ userInfo && userInfo.phone }}">
      <button class="avatar-action avatar-primary" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        使用微信头像
      </button>
      <button class="avatar-action" bindtap="chooseAvatarFromAlbum">
        从相册选择
      </button>
    </view>
  </view>

  <view class="menu-section">
    <van-cell-group inset>
      <van-cell
        title="我的订单"
        icon="orders-o"
        is-link
        bind:click="goToOrders"
      />
      <van-cell
        title="个人资料"
        icon="user-o"
        is-link
        bind:click="navigateToEdit"
      />
    </van-cell-group>
  </view>

  <view class="logout-section" wx:if="{{ userInfo && userInfo.phone }}">
    <van-button block round color="#ee0a24" plain bindtap="handleLogout">
      退出登录
    </van-button>
  </view>

  <view class="logout-section" wx:else>
    <van-button block round type="primary" bindtap="goToLogin">
      去登录
    </van-button>
  </view>

  <van-dialog id="van-dialog" />
</view>
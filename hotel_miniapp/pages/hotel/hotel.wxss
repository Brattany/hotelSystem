.hotel-page {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.hotel-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx; 
}

.hotel-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  transition: all 0.2s;
}

.hotel-item:active {
  transform: scale(0.98); 
}

.hotel-img {
  width: 180rpx;
  height: 220rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background-color: #f2f3f5; 
}

.hotel-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden; 
}

.hotel-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #323233;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hotel-address {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hotel-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hotel-action {
  margin-top: auto;
  display: flex;
  justify-content: flex-end;
}

.view-btn {
  font-size: 24rpx;
  color: #fff;
  background-color: #1989fa;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}
.detail-page {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.hero-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.hero-image {
  width: 100%;
  height: 360rpx;
  background-color: #f2f3f5;
}

.hero-content {
  padding: 28rpx;
}

.hotel-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #323233;
}

.hotel-address {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #969799;
  line-height: 1.6;
}

.hotel-summary {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #646566;
}

.detail-section {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.entry-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.06);
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.entry-desc {
  margin: 16rpx 0 20rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #969799;
}

.flow-list {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background-color: #f7f8fa;
}

.flow-item {
  font-size: 24rpx;
  line-height: 1.8;
  color: #646566;
}

.tag-item {
  margin-right: 0 !important;
}
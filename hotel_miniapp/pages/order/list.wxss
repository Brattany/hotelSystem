.order-container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

.order-list {
  padding: 24rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #ebedf0;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}

.order-id {
  font-size: 28rpx;
  color: #323233;
  font-weight: bold;
}

.order-status {
  font-size: 26rpx;
}

/* 动态状态颜色 */
.status--1 { color: #969799; } /* 已取消: 灰色 */
.status-0 { color: #ee0a24; } /* 待支付: 红色 */
.status-1 { color: #ff976a; } /* 待入住: 橙色 */
.status-2 { color: #1989fa; } /* 已入住: 蓝色 */
.status-3 { color: #07c160; } /* 已完成: 绿色 */

.card-body {
  font-size: 26rpx;
  color: #646566;
  line-height: 1.8;
}

.hotel-info-block {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.hotel-name {
  font-size: 30rpx;
  color: #323233;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.info-line {
  word-break: break-all;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #ebedf0;
}

.price {
  font-size: 32rpx;
  color: #323233;
  font-weight: bold;
}

.currency {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.action-btn-group {
  display: flex;
  gap: 16rpx;
}

.pay-btn {
  margin-left: 16rpx;
}

<view class="order-container">
  <van-tabs active="{{ activeTab }}" bind:change="onTabChange" color="#1989fa" sticky>
    <van-tab title="All" name="all"></van-tab>
    <van-tab title="Pending Pay" name="1"></van-tab>
    <van-tab title="Pending Stay" name="2"></van-tab>
    <van-tab title="Done" name="5"></van-tab>
  </van-tabs>

  <view class="order-list">
    <van-empty wx:if="{{ filteredOrders.length === 0 }}" description="No orders" />

    <view class="order-card" wx:for="{{ filteredOrders }}" wx:key="reservationId">
      <view class="card-header">
        <view class="hotel-name">Order: {{ item.reservationId }}</view>
        <view class="order-status {{ 'status-' + item.status }}">
          {{ statusMap[item.status] || 'Unknown' }}
        </view>
      </view>

      <view class="card-body">
        <view class="info-line">Room: {{ item.typeName || '-' }}</view>
        <view class="info-line">Check In: {{ item.checkInDate || '-' }}</view>
        <view class="info-line">Check Out: {{ item.checkOutDate || '-' }}</view>
        <view class="info-line">Guest: {{ item.guestName || '-' }}</view>
      </view>

      <view class="card-footer">
        <view class="price">Total: <text class="currency">¥</text>{{ item.totalPrice || 0 }}</view>

        <view class="action-btn-group">
          <van-button
            wx:if="{{ item.status === 1 }}"
            size="small"
            type="danger"
            plain
            bindtap="cancelOrder"
            data-id="{{ item.reservationId }}"
          >
            Cancel
          </van-button>

          <van-button
            wx:if="{{ item.status === 1 }}"
            size="small"
            type="primary"
            bindtap="goToPay"
            data-id="{{ item.reservationId }}"
            data-price="{{ item.totalPrice }}"
            custom-class="pay-btn"
          >
            Pay
          </van-button>
        </view>
      </view>
    </view>
  </view>

  <van-dialog id="van-dialog" />
</view>
